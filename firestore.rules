rules_version = '2';

// wise-meishi プロジェクト用 Firestoreルール
// 全営業共有の名刺台帳。認証ユーザーのみアクセス可。
// ロール: admin / editor / viewer（users コレクションで管理）

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && role() == 'admin';
    }

    // 名刺データ（サムネ込み・一覧で読む）
    // 閲覧=全ログインユーザー / 登録・編集・削除= director(admin) のみ
    match /cards/{cardId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 名刺原本画像（詳細表示時のみ読む・一覧クエリから分離）
    match /cardImages/{cardId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ユーザー（ロール管理）
    match /users/{uid} {
      // 自分のレコードは読める。最初のログインで viewer 自己登録のみ許可
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.role == 'viewer';
      // ロール変更は admin のみ
      allow update, delete: if isSignedIn() && role() == 'admin';
      // admin は全ユーザー閲覧可
      allow read: if isSignedIn() && role() == 'admin';
    }

    // 設定（Geminiキー等）。読み取りは認証ユーザー、書き込みは admin
    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && role() == 'admin';
    }
  }
}
