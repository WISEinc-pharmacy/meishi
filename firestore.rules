rules_version = '2';

// wise-meishi プロジェクト用 Firestoreルール
// usersはメールアドレスをキーに管理（budget-tool準拠）。adminがメールで事前にユーザー追加・権限付与・削除できる。
// 閲覧=全ログインユーザー / 登録・編集・削除・権限変更= admin のみ

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function em() { return request.auth.token.email; }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(em()))
        && get(/databases/$(database)/documents/users/$(em())).data.role == 'admin';
    }

    // 名刺データ（サムネ込み・一覧で読む）
    match /cards/{cardId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 名刺原本画像（詳細表示時のみ読む・一覧クエリから分離）
    match /cardImages/{cardId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ユーザー（メールアドレスがドキュメントID）
    // ・自分のドキュメントは読める / 未登録者は viewer として自己登録のみ可
    // ・追加(他人)・権限変更・削除は admin のみ
    match /users/{email} {
      allow read: if isSignedIn() && (em() == email || isAdmin());
      allow create: if isSignedIn() && em() == email && request.resource.data.role == 'viewer';
      allow create, update, delete: if isAdmin();
    }

    // 設定（Geminiキー等）。読み取りは認証ユーザー、書き込みは admin
    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
