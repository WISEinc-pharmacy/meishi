rules_version = '2';

// wise-meishi 用 Storageルール
// 名刺画像（cards/{id}/...）は認証ユーザーのみ読み書き可。
service firebase.storage {
  match /b/{bucket}/o {
    match /cards/{cardId}/{file} {
      allow read, write: if request.auth != null;
    }
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
